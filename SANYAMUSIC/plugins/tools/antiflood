@app.on_message(filters.command("setflood") & filters.group)
async def set_flood_limit(_, m: Message):
    if not await is_admin(m.chat.id, m.from_user.id):
        return await m.reply_text(" бҙҸЙҙКҹКҸ бҙҖбҙ…бҙҚЙӘЙҙs бҙ„бҙҖЙҙ бҙңsбҙҮ бҙӣКңЙӘs бҙ„бҙҸбҙҚбҙҚбҙҖЙҙбҙ….")
    if len(m.command) < 2:
        return await m.reply_text("бҙңsбҙҖЙўбҙҮ: `/setflood <ЙҙбҙңбҙҚКҷбҙҮКҖ|бҙҸТ“Т“>`")

    arg = m.command[1].lower()
    if arg in ["off", "no", "0"]:
        await set_flood_settings(m.chat.id, {"limit": 0})
        return await m.reply_text(" бҙҖЙҙбҙӣЙӘТ“КҹбҙҸбҙҸбҙ… бҙ…ЙӘsбҙҖКҷКҹбҙҮбҙ….")

    try:
        limit = int(arg)
        if limit < 2:
            raise ValueError
    except ValueError:
        return await m.reply_text(" ЙӘЙҙбҙ бҙҖКҹЙӘбҙ… бҙ бҙҖКҹбҙңбҙҮ.")

    await set_flood_settings(m.chat.id, {"limit": limit})
    await m.reply_text(f" бҙҖЙҙбҙӣЙӘТ“КҹбҙҸбҙҸбҙ… бҙӣКҖЙӘЙўЙўбҙҮКҖ бҙҖТ“бҙӣбҙҮКҖ `{limit}` бҙҚбҙҮssбҙҖЙўбҙҮs.")


@app.on_message(filters.command("setfloodmode") & filters.group)
async def set_flood_action(_, m: Message):
    if not await is_admin(m.chat.id, m.from_user.id):
        return await m.reply_text(" бҙҸЙҙКҹКҸ бҙҖбҙ…бҙҚЙӘЙҙs бҙ„бҙҖЙҙ бҙңsбҙҮ бҙӣКңЙӘs бҙ„бҙҸбҙҚбҙҚбҙҖЙҙбҙ….")
    if len(m.command) < 2:
        return await m.reply_text("бҙңsбҙҖЙўбҙҮ: `/setfloodmode <КҷбҙҖЙҙ/бҙҚбҙңбҙӣбҙҮ/бҙӢЙӘбҙ„бҙӢ/бҙӣКҷбҙҖЙҙ/бҙӣбҙҚбҙңбҙӣбҙҮ> [бҙ…бҙңКҖбҙҖбҙӣЙӘбҙҸЙҙ]`")

    action = m.command[1].lower()
    if action not in ["ban", "mute", "kick", "tban", "tmute"]:
        return await m.reply_text(" ЙӘЙҙбҙ бҙҖКҹЙӘбҙ… бҙҖбҙ„бҙӣЙӘбҙҸЙҙ.")

    duration = m.command[2] if len(m.command) >= 3 else None
    if action in ["tban", "tmute"] and not parse_time(duration):
        return await m.reply_text(" бҙҳКҹбҙҮбҙҖsбҙҮ ЙўЙӘбҙ бҙҮ бҙ бҙҖКҹЙӘбҙ… бҙ…бҙңКҖбҙҖбҙӣЙӘбҙҸЙҙ (e.g. 30s, 5m, 2h).")

    await set_flood_settings(m.chat.id, {"action": action, "duration": duration})
    await m.reply_text(f" бҙҖбҙ„бҙӣЙӘбҙҸЙҙ sбҙҮбҙӣ бҙӣбҙҸ `{action}` {duration or ''}.")


@app.on_message(filters.command("setfloodtimer") & filters.group)
async def set_flood_timer(_, m: Message):
    if not await is_admin(m.chat.id, m.from_user.id):
        return await m.reply_text(" бҙҸЙҙКҹКҸ бҙҖбҙ…бҙҚЙӘЙҙs бҙ„бҙҖЙҙ бҙңsбҙҮ бҙӣКңЙӘs бҙ„бҙҸбҙҚбҙҚбҙҖЙҙбҙ….")
    if len(m.command) < 3:
        return await m.reply_text("бҙңsбҙҖЙўбҙҮ: `/setfloodtimer <бҙҚsЙўs> <бҙӣЙӘбҙҚбҙҮ>`")

    if m.command[1].lower() in ["off", "no"]:
        await set_flood_settings(m.chat.id, {"timer": None})
        return await m.reply_text(" бҙӣЙӘбҙҚбҙҮбҙ… бҙҖЙҙбҙӣЙӘТ“КҹбҙҸбҙҸбҙ… бҙ…ЙӘsбҙҖКҷКҹбҙҮбҙ….")

    try:
        msgs = int(m.command[1])
        secs = parse_time(m.command[2])
        if msgs < 1 or not secs:
            raise ValueError
    except Exception:
        return await m.reply_text(" ЙӘЙҙбҙ бҙҖКҹЙӘбҙ… Т“бҙҸКҖбҙҚбҙҖбҙӣ. бҙҮx: `/setfloodtimer 10 30s`")

    await set_flood_settings(m.chat.id, {"timer": {"messages": msgs, "seconds": secs}})
    await m.reply_text(f" бҙӣЙӘбҙҚбҙҮбҙ… бҙҖЙҙбҙӣЙӘТ“КҹбҙҸбҙҸбҙ…: `{msgs}` бҙҚsЙўs / `{secs}s`.")


@app.on_message(filters.command("clearflood") & filters.group)
async def clear_flood_msgs(_, m: Message):
    if not await is_admin(m.chat.id, m.from_user.id):
        return await m.reply_text(" бҙҸЙҙКҹКҸ бҙҖбҙ…бҙҚЙӘЙҙs бҙ„бҙҖЙҙ бҙңsбҙҮ бҙӣКңЙӘs бҙ„бҙҸбҙҚбҙҚбҙҖЙҙбҙ….")
    if len(m.command) < 2:
        return await m.reply_text("бҙңsбҙҖЙўбҙҮ: `/clearflood on|off`")

    arg = m.command[1].lower()
    state = arg in ["on", "yes", "true"]
    await set_flood_settings(m.chat.id, {"clear": state})
    await m.reply_text(f" бҙ„КҹбҙҮбҙҖКҖ Т“КҹбҙҸбҙҸбҙ… бҙҚбҙҮssбҙҖЙўбҙҮs: `{state}`")


@app.on_message(filters.group & ~filters.service & ~filters.bot)
async def flood_handler(_, message: Message):
    if not message.from_user:
        return

    chat_id = message.chat.id
    user_id = message.from_user.id
    now = time.time()

    settings = await get_flood_settings(chat_id)
    limit = settings.get("limit", DEFAULT_LIMIT)
    if not limit or limit <= 0:
        return

    key = (chat_id, user_id)
    timer = settings.get("timer")

    async with tracker_lock:
        entry = user_flood_tracker.get(key)
        if not entry:
            user_flood_tracker[key] = {"count": 1, "time": now}
            return
        entry["count"] += 1
        if timer:
            msgs = timer.get("messages")
            secs = timer.get("seconds")
            if not msgs or not secs:
                if entry["count"] >= limit:
                    await take_action(message, settings)
                    user_flood_tracker.pop(key, None)
                return

            if now - entry["time"] <= secs and entry["count"] >= msgs:
                await take_action(message, settings)
                user_flood_tracker.pop(key, None)
            elif now - entry["time"] > secs:
                user_flood_tracker[key] = {"count": 1, "time": now}
        else:
            if entry["count"] >= limit:
                await take_action(message, settings)
                user_flood_tracker.pop(key, None)


async def take_action(message: Message, settings: dict):
    chat_id = message.chat.id
    user = message.from_user
    action = settings.get("action", "mute")
    duration = settings.get("duration")
    clear = settings.get("clear", False)

    try:
        if clear:
            try:
                await message.delete()
            except Exception:
                pass

        if action == "ban":
            await app.ban_chat_member(chat_id, user.id)
            await message.reply_text(f" {user.mention} КҷбҙҖЙҙЙҙбҙҮбҙ… Т“бҙҸКҖ Т“КҹбҙҸбҙҸбҙ…ЙӘЙҙЙў.")
        elif action == "mute":
            perms = ChatPermissions(can_send_messages=False)
            await app.restrict_chat_member(chat_id, user.id, permissions=perms)
            await message.reply_text(f" {user.mention} бҙҚбҙңбҙӣбҙҮбҙ… Т“бҙҸКҖ Т“КҹбҙҸбҙҸбҙ…ЙӘЙҙЙў.")
        elif action == "kick":
            await app.ban_chat_member(chat_id, user.id)
            await app.unban_chat_member(chat_id, user.id)
            await message.reply_text(f" {user.mention} бҙӢЙӘбҙ„бҙӢбҙҮбҙ… Т“бҙҸКҖ Т“КҹбҙҸбҙҸбҙ…ЙӘЙҙЙў.")
        elif action in ["tban", "tmute"] and duration:
            seconds = parse_time(duration)
            if not seconds:
                await message.reply_text(" ЙӘЙҙбҙ бҙҖКҹЙӘбҙ… бҙ…бҙңКҖбҙҖбҙӣЙӘбҙҸЙҙ бҙ„бҙҸЙҙкң°ЙӘЙўбҙңКҖбҙҮбҙ….")
                return
            until_date = int(time.time() + seconds)
            if action == "tban":
                await app.ban_chat_member(chat_id, user.id, until_date=until_date)
                await message.reply_text(f" {user.mention} бҙӣбҙҮбҙҚбҙҳ КҷбҙҖЙҙЙҙбҙҮбҙ… Т“бҙҸКҖ {duration}.")
            else:
                perms = ChatPermissions(can_send_messages=False)
                await app.restrict_chat_member(chat_id, user.id, permissions=perms, until_date=until_date)
                await message.reply_text(f" {user.mention} бҙӣбҙҮбҙҚбҙҳ бҙҚбҙңбҙӣбҙҮбҙ… Т“бҙҸКҖ {duration}.")
    except Exception as e:
        print("[antiflood] action error:", repr(e))


async def _cleanup_tracker():
    while True:
        await asyncio.sleep(CLEANUP_INTERVAL)
        cutoff = time.time() - MAX_RETENTION
        async with tracker_lock:
            keys_to_pop = [k for k, v in user_flood_tracker.items() if v.get("time", 0) < cutoff]
            for k in keys_to_pop:
                user_flood_tracker.pop(k, None)


asyncio.get_event_loop().create_task(_cleanup_tracker())
